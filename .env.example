# ==========================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# ==========================================

# Port the backend server will run on
PORT=5000

# MongoDB Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/todoApp

# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET=your_jwt_super_secret_key_here

# Nodemailer SMTP Configuration (e.g. Gmail)
EMAIL_USER=your-email@gmail.com
# For Gmail, generate an App Password in your account security settings
EMAIL_PASS=your-gmail-app-password

# Allowed client origin (CORS)
FRONTEND_URL=http://localhost:5173


# ==========================================
# FRONTEND ENVIRONMENT VARIABLES (frontend/.env)
# ==========================================

# Target API endpoint URL for backend requests
VITE_API_URL=http://localhost:5000/api
